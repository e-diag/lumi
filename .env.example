# ============================================================
# FreeWay VPN — переменные окружения
# Скопируй в .env и заполни реальными значениями
# ============================================================

# Публичный URL сервера (для генерации subscription URL)
BASE_URL=https://api.freeway-vpn.ru

# PostgreSQL DSN (локально: localhost; в docker-compose: хост postgres)
DATABASE_DSN=postgres://freeway:password@localhost:5432/freeway?sslmode=disable
# DATABASE_DSN=postgres://freeway:password@postgres:5432/freeway?sslmode=disable

# Секрет для подписи JWT-токенов (мин. 32 символа)
JWT_SECRET=change-me-to-a-secure-random-string-32chars

# Токен Telegram-бота (от @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Имя бота без @ (для реферальных ссылок t.me/...)
TELEGRAM_BOT_USERNAME=FreeWayVPNBot

# ID менеджеров в Telegram (через запятую, для /manager и админ-панели в боте)
TELEGRAM_ADMIN_IDS=123456789,987654321

# Ссылки на клиенты (кнопки в боте «Скачать приложение»; можно оставить пустыми)
TELEGRAM_APP_URL_IOS=https://apps.apple.com/app/id0000000000
TELEGRAM_APP_URL_ANDROID=https://www.rustore.ru/catalog/app/...

# Remnawave API
REMNAWAVE_BASE_URL=https://remnawave.example.com
REMNAWAVE_API_KEY=remnawave-api-key

# ЮKassa
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# EU нода (Hetzner, Нидерланды)
NODE_EU_HOST=eu.freeway-vpn.ru
NODE_EU_PUBLIC_KEY=your-eu-node-public-key
NODE_EU_SHORT_ID=your-eu-short-id

# USA нода (Vultr/DO)
NODE_USA_HOST=usa.freeway-vpn.ru
NODE_USA_PUBLIC_KEY=your-usa-node-public-key
NODE_USA_SHORT_ID=your-usa-short-id

# CDN нода (Yandex Cloud)
NODE_CDN_HOST=cdn.freeway-vpn.ru
NODE_CDN_SNI=cdn.freeway-vpn.ru

# Веб-панель менеджера
ADMIN_WEB_TOKEN=change-me-admin-token
